# Google Places API (New) key. Get from https://console.cloud.google.com/apis/credentials
# Enable "Places API (New)" on the project. Billing must be on.
GOOGLE_PLACES_API_KEY=

# Twilio credentials. Get from https://console.twilio.com
# Only required if Twilio Lookup validation is enabled in the form.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Nominatim (OpenStreetMap) User-Agent. Required — Nominatim ToS blocks requests without a real,
# contact-identifying UA. Format: "<app-name>/<version> (<contact-email>)".
NOMINATIM_USER_AGENT=microagi-lead-gen/1.0 (ops@micro-agi.com)

# Google OAuth credentials for Auth.js (NextAuth v5). Create at
# https://console.cloud.google.com/apis/credentials → "Create OAuth client ID" → Web application.
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
# (for local dev also add http://localhost:3000/api/auth/callback/google)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Random 32+ byte secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google Workspace domain allowed to sign in. Change if the org domain changes.
AUTH_ALLOWED_DOMAIN=micro-agi.com

# Extra individual emails allowed in (comma-separated, case-insensitive). Use for
# outside collaborators who aren't on the Workspace domain. Leave empty for none.
# Example: AUTH_ALLOWED_EMAILS=alice@gmail.com,bob@partner.co
AUTH_ALLOWED_EMAILS=

# Groq API key for LLM industry enrichment (runs before Attio push). Free tier is
# 30 req/min — plenty for a 500-place run (~5 batch requests). Get from
# https://console.groq.com (no credit card required). Optional — if absent,
# enrichment is skipped and the Industry column in Attio stays empty.
GROQ_API_KEY=

# Attio workspace API key. Stored server-side; users never see it. Required for
# any CRM read/write (lead push, manual ingest, /tracking page). Generate in
# Attio → Workspace settings → Developers → Create access token.
ATTIO_API_KEY=

# Shared password that users enter in /settings to unlock Attio features in
# their session. Keep it a real secret — anyone with this string can read/write
# the CRM through the app. Rotate by changing the env var (forces re-unlock).
ATTIO_ACCESS_PASSWORD=

# GoHighLevel (LeadConnector) credentials. Used by the iOS app's pickup flow
# to read calendly-tagged contacts and swap outcome tags. Generate the API
# key in GHL → Settings → API → Private Integrations.
GHL_API_KEY=
# Sub-account location ID the integration is scoped to.
GHL_LOCATION_ID=
# Override only if pointing at a different host (default is the public API).
GHL_API_BASE=https://services.leadconnectorhq.com

# Environment mode (development | production). Next.js sets this automatically.
NODE_ENV=development
